// Phase 4: packages with persistent state
package counter is
    counter int;
    proc inc() -> int;
    func get() -> int;
end counter;

package body counter is
    int counter = 0;

    proc inc() -> int {
        counter = counter + 1;
        return 0;
    }

    func get() -> int {
        return counter;
    }
end counter;

proc main() -> int {
    counter.inc();
    counter.inc();
    counter.inc();
    print int_to_string(counter.get());
    return counter.get();
}
